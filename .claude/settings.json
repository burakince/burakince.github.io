{
  "plansDirectory": "./project-plans",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/scripts/update-post-modified.py",
            "statusMessage": "Updating lastModified in post front matter..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/scripts/check-emnapi-lock.py",
            "statusMessage": "Checking @emnapi lock file entries..."
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/update-tailwind-vscode.py",
            "statusMessage": "Updating .vscode/tailwind.json for installed Tailwind version..."
          }
        ]
      }
    ]
  }
}
